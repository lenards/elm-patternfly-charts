{
    "type": "package",
    "name": "lenards/elm-patternfly-charts",
    "summary": "PatternFly v6 chart components for Elm, powered by gampleman/elm-visualization",
    "license": "BSD-3-Clause",
    "version": "1.0.1",
    "exposed-modules": {
        "PF6.Charts": [
            "PF6.Charts.Colors",
            "PF6.Charts.Theme",
            "PF6.Charts.Area",
            "PF6.Charts.Bar",
            "PF6.Charts.BoxPlot",
            "PF6.Charts.Bullet",
            "PF6.Charts.Donut",
            "PF6.Charts.DonutUtilization",
            "PF6.Charts.Line",
            "PF6.Charts.Pie",
            "PF6.Charts.Scatter",
            "PF6.Charts.Sparkline",
            "PF6.Charts.Stack",
            "PF6.Charts.Threshold",
            "PF6.Charts.Skeleton"
        ]
    },
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/html": "1.0.0 <= v < 2.0.0",
        "elm/svg": "1.0.1 <= v < 2.0.0",
        "folkertdev/one-true-path-experiment": "5.0.0 <= v < 7.0.0",
        "gampleman/elm-visualization": "2.4.0 <= v < 3.0.0"
    },
    "test-dependencies": {}
}
